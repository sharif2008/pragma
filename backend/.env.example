# Copy to backend/.env and adjust.
# Create database: mysql -u root -p < db/init_mysql.sql
DATABASE_URL=mysql+pymysql://root:test@127.0.0.1:3306/agentic-vfl
STORAGE_ROOT=

# Optional: real LLM reasoning (otherwise mock agent + mock RAG answers)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# File logs (default: backend/logs/app.log)
# LOG_DIR=logs

# HuggingFace / SentenceTransformers cache (default: storage/hf_home)
# HF_HOME=storage/hf_home
